(* ShaderView — a generic full-screen PIXEL-SHADER host on Direct3D11. A demo
   supplies its own HLSL pixel shader and a constant buffer; ShaderView draws one
   full-screen triangle per frame and Presents. The fractal/plasma/effect lives
   entirely in the demo's pixel shader; everything here is the D3D11 plumbing.

   The Direct3D11/DXGI COM interfaces it drives are the winapi-gen-generated,
   @ordinal-checked ones (no hand-counted vtables). First cut: fixed-size window.

   Usage:
     ok  := ShaderView.Startup();
     win := WinShell.CreateAppWindow(title, w, h, Handler);
     WinShell.Show(win);  WinShell.ClientSize(win, cw, ch);
     ok  := ShaderView.Attach(win, cw, ch);
     ok  := ShaderView.SetShader(myPixelHlsl, SIZE(myConstants));
     ShaderView.RunLoop(BuildConstants);   (* BuildConstants(time) -> ADR(myConstants) *)
*)
DEFINITION MODULE ShaderView;

FROM SYSTEM IMPORT ADDRESS;

TYPE
  (* Called once per frame: given the elapsed time in seconds, fill the demo's
     constant-buffer record and return its address. *)
  BuildProc = PROCEDURE (SHORTREAL): ADDRESS;

  Instance = ADDRESS;               (* an instanced renderer (own device + swapchain); NIL = none *)

(* ---- instancing (S3): several renderers coexist, each owning its own D3D11
   device + swapchain + render target + shaders + textures + sprite layer (so
   GameViewGpu can layer one per game). Every singleton procedure below operates
   on the *current* renderer (Use); an eager default backs the legacy singleton
   API. Create/Free are headless; Attach (device + swapchain) needs a real
   window. ---- *)
PROCEDURE Create (): Instance;
PROCEDURE Use    (i: Instance);
PROCEDURE Free   (VAR i: Instance);

(* One-time init (the d3d11/d3dcompiler entry points load lazily). *)
PROCEDURE Startup (): BOOLEAN;

(* Create the device + swapchain + render-target view bound to `hwnd`, and the
   fixed full-screen-triangle vertex shader. Fixed size. FALSE on failure. *)
PROCEDURE Attach (hwnd: ADDRESS; w, h: CARDINAL): BOOLEAN;

(* Compile the demo's pixel shader (HLSL source as a normal wide string; entry
   `main`, target ps_4_0) and create a constant buffer of `cbSize` bytes (round
   it to a 16-byte multiple). Call after Attach. FALSE on failure. *)
PROCEDURE SetShader (pixelHlsl: ARRAY OF CHAR; cbSize: CARDINAL): BOOLEAN;

(* --- input textures (for an index buffer + palette-LUT present, or any
   sampled-texture shader) --------------------------------------------------
   Bind a `w` x `h` shader-resource texture at SRV register t<slot> (slot 0..7)
   with the given DXGI format. The pixel shader reads it with Load() (an exact
   integer fetch — no sampler, no filtering). Typical retro/indexed present:
     BindTexture(0, fbW, fbH, 62);   (* 62 = DXGI_FORMAT_R8_UINT, the index buffer *)
     BindTexture(1, 256,  1, 87);    (* 87 = DXGI_FORMAT_B8G8R8A8_UNORM, a 256-entry
                                        palette LUT; reads a 0x00RRGGBB word as .rgb *)
   Create after Attach; the bound SRVs are set before every Frame's Draw. FALSE on
   failure. *)
PROCEDURE BindTexture (slot, w, h: CARDINAL; format: INTEGER32): BOOLEAN;

(* Upload pixel bytes into the texture at `slot` (UpdateSubresource). `rowPitch` =
   bytesPerTexel * w (e.g. w for R8_UINT; 256*4 for the palette LUT). Call per
   frame for a changing buffer (index, or the palette while cycling); once for a
   static one. *)
PROCEDURE UploadTexture (slot: CARDINAL; pixels: ADDRESS; rowPitch: CARDINAL);

(* The client area size (so a demo can compute an aspect ratio). *)
PROCEDURE Width (): CARDINAL;
PROCEDURE Height (): CARDINAL;

(* Render one frame: copy `cbSize` bytes from `constants` into the constant
   buffer, draw the full-screen triangle, Present(1,0). No-op if not ready.
   (= BeginFrame + EndFrame, with no sprite pass between.) *)
PROCEDURE Frame (constants: ADDRESS);

(* --- sprite layer: a 2nd alpha-blended quad pass over the background --------
   Sprites are 16-colour indexed bitmaps in a shared atlas (index 0 transparent),
   each drawing through its own row of a palette LUT, composited OVER the resolved
   index->RGBA background (the way winscheme does it). Create once after Attach:
   an atlasW x atlasH R8_UINT atlas, a palW x palH B8G8R8A8 palette LUT (row =
   sprite slot, column = colour index), and a vertex buffer of `maxVerts` vertices
   (6 floats each). FALSE on failure. *)
PROCEDURE InitSprites (atlasW, atlasH, palW, palH, maxVerts: CARDINAL): BOOLEAN;
PROCEDURE UploadAtlas (pixels: ADDRESS; rowPitch: CARDINAL);          (* rowPitch = atlasW *)
PROCEDURE UploadSpritePalette (pixels: ADDRESS; rowPitch: CARDINAL);  (* rowPitch = palW*4 *)

(* The two-pass frame, split so sprites can be drawn between background and present:
     BeginFrame(bg);  DrawSprites(verts, n);  EndFrame;
   Each sprite vertex is 6 floats: pos.x pos.y (NDC), uv.x uv.y (atlas PIXELS),
   meta.x (palette slot) meta.y (alpha 0..1). Two triangles (6 verts) per quad. *)
PROCEDURE BeginFrame (constants: ADDRESS);
PROCEDURE DrawSprites (verts: ADDRESS; vertCount: CARDINAL);
PROCEDURE EndFrame;

(* Continuous loop: pump Win32 messages (WinShell.PumpMessages), advance a time
   counter, call `build(time)` to get the frame's constants, Frame() them, until
   WM_QUIT. The demo's window handler updates view state on input; `build` reads
   it. *)
PROCEDURE RunLoop (build: BuildProc);

(* Resize hook — STUB (fixed-size window). *)
PROCEDURE Resize (w, h: CARDINAL);

(* Release all D3D resources. Safe to call repeatedly. *)
PROCEDURE Shutdown;

END ShaderView.
