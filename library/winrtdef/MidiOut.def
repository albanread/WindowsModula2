(* MidiOut — live MIDI playback of an Abc.Tune through WinMM midiOut, direct from
   Modula-2 (a port of NewAudio's midi_runtime). A background scheduler thread on a
   1 ms timer fires each pre-timed event the instant its absolute-ms deadline
   passes — no music math at play time, no GC pauses, so note timing stays tight.

   Usage:
     ok := MidiOut.Startup();
     IF Abc.ParseTune(abcText, tune) THEN MidiOut.Play(tune) END;
     ... WHILE MidiOut.IsPlaying() DO ... END;
     MidiOut.Shutdown;
*)
DEFINITION MODULE MidiOut;

FROM Abc IMPORT Tune;

PROCEDURE Startup (): BOOLEAN;     (* open the GM synth + start the scheduler thread *)
PROCEDURE Shutdown;

(* MUSIC and SOUND are separate. Play drives the single "music" track; PlaySfx fires
   a one-shot effect on its own voice and layers OVER the music without stopping it.
   Each runs concurrently and cleans up only its own notes. *)
PROCEDURE Play (VAR t: Tune);      (* music: play `t` on the music track (the caller owns `t`) *)
PROCEDURE PlaySfx (VAR t: Tune);   (* sound effect: play `t` on a free SFX voice, music keeps going *)
PROCEDURE Stop;                    (* stop every track + all-notes-off *)
PROCEDURE IsPlaying (): BOOLEAN;   (* is the music track still playing *)

(* A sustained pad note on a reserved channel: it keeps ringing across Play cue
   switches (only Stop/Shutdown silence it). `prog` is a GM program (e.g. 89 = warm
   pad), `note` a MIDI note, `vel` 0..127. Call Drone again to change it. *)
PROCEDURE Drone (prog, note, vel: CARDINAL);
PROCEDURE DroneOff;

END MidiOut.
