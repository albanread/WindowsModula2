DEFINITION MODULE Socket;

(* TCP/IP sockets over Winsock2 (ws2_32), wrapped into a small byte-oriented
   API in pure Modula-2. Call Startup once before any socket use and Shutdown at
   the end. The connection procedures return TRUE and set the socket via VAR, or
   FALSE on failure (LastError gives the Winsock code). Send/Recv move raw bytes
   (layer Utf8 / your own framing on top).

     IF Socket.Startup() THEN
       IF Socket.Connect("127.0.0.1", 8080, s) THEN
         ok := Socket.SendAll(s, ADR(buf), n);
         ok := Socket.Recv(s, ADR(rbuf), 256, got);   (* got=0 => peer closed *)
         Socket.Close(s)
       END;
       Socket.Shutdown
     END *)

FROM SYSTEM IMPORT ADDRESS;

TYPE Socket = ADDRESS;                  (* an OS socket handle *)

PROCEDURE Startup  (): BOOLEAN;         (* WSAStartup (Winsock 2.2) *)
PROCEDURE Shutdown;                     (* WSACleanup *)

PROCEDURE Connect (host: ARRAY OF CHAR; port: CARDINAL; VAR s: Socket): BOOLEAN;
(* connect a TCP client to host:port; host is a dotted-quad IP or a name (resolved) *)
PROCEDURE Listen  (port, backlog: CARDINAL; VAR s: Socket): BOOLEAN;   (* bind INADDR_ANY:port + listen *)
PROCEDURE Accept  (server: Socket; VAR client: Socket): BOOLEAN;       (* blocks for a connection *)

PROCEDURE Send    (s: Socket; data: ADDRESS; len: CARDINAL; VAR sent: CARDINAL): BOOLEAN;
PROCEDURE SendAll (s: Socket; data: ADDRESS; len: CARDINAL): BOOLEAN;  (* loops until all len bytes are sent *)
PROCEDURE Recv    (s: Socket; buf: ADDRESS; len: CARDINAL; VAR got: CARDINAL): BOOLEAN;
                                        (* one stream read: got = bytes arrived (<= len, may be partial);
                                           got=0 means the peer closed cleanly; FALSE = error *)
PROCEDURE RecvAll (s: Socket; buf: ADDRESS; len: CARDINAL): BOOLEAN;   (* read EXACTLY len bytes; FALSE if peer closes first *)
PROCEDURE Close   (VAR s: Socket);

PROCEDURE LastError (): CARDINAL;       (* WSAGetLastError *)

(* --- non-blocking mode ---
   After SetBlocking(s, FALSE), Connect/Send/Recv return immediately; a call that
   can't complete yet returns FALSE with WouldBlock() = TRUE (retry later) rather
   than blocking. This is the reactor style; SocketServer offers the proactor
   (IOCP) style for scalable servers. *)
PROCEDURE SetBlocking (s: Socket; blocking: BOOLEAN): BOOLEAN;
PROCEDURE WouldBlock  (): BOOLEAN;      (* last failure was "would block", not a real error *)

(* --- UDP (datagrams) ---
   UdpSocket makes a datagram socket; BindPort binds it to a local port (for a
   receiver/server); SendTo/RecvFrom carry the peer address per datagram.
     IF Socket.UdpSocket(u) AND Socket.BindPort(u, 9000) THEN
       IF Socket.RecvFrom(u, ADR(buf), 1500, n, host, port) THEN ... END *)
PROCEDURE UdpSocket (VAR s: Socket): BOOLEAN;
PROCEDURE BindPort  (s: Socket; port: CARDINAL): BOOLEAN;                 (* bind INADDR_ANY:port *)
PROCEDURE SendTo    (s: Socket; host: ARRAY OF CHAR; port: CARDINAL;
                     data: ADDRESS; len: CARDINAL; VAR sent: CARDINAL): BOOLEAN;
PROCEDURE RecvFrom  (s: Socket; buf: ADDRESS; len: CARDINAL; VAR got: CARDINAL;
                     VAR fromHost: ARRAY OF CHAR; VAR fromPort: CARDINAL): BOOLEAN;

(* --- socket options --- *)
PROCEDURE SetReuseAddr (s: Socket; on: BOOLEAN): BOOLEAN;   (* SO_REUSEADDR (rebind a recently-used port) *)
PROCEDURE SetNoDelay   (s: Socket; on: BOOLEAN): BOOLEAN;   (* TCP_NODELAY (disable Nagle, send small writes now) *)

END Socket.
