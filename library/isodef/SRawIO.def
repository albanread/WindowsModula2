DEFINITION MODULE SRawIO;

IMPORT SYSTEM;

PROCEDURE Read  (VAR to: ARRAY OF SYSTEM.LOC);
PROCEDURE Write (from: ARRAY OF SYSTEM.LOC);

END SRawIO.
