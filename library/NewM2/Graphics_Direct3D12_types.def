TYPE
    D3D12_ADAPTER_FAMILY = RECORD
        szAdapterFamily : ARRAY [0..127] OF CHAR;
    END;
    D3D12_APPLICATION_DESC = RECORD
        pExeFilename : PWSTR;
        pName : PWSTR;
        Version : D3D12_VERSION_NUMBER;
        pEngineName : PWSTR;
        EngineVersion : D3D12_VERSION_NUMBER;
    END;
    D3D12_AUTO_BREADCRUMB_NODE = RECORD
        pCommandListDebugNameA : POINTER TO BYTE;
        pCommandListDebugNameW : PWSTR;
        pCommandQueueDebugNameA : POINTER TO BYTE;
        pCommandQueueDebugNameW : PWSTR;
        pCommandList : ADDRESS;
        pCommandQueue : ADDRESS;
        BreadcrumbCount : DWORD;
        pLastBreadcrumbValue : POINTER TO DWORD;
        pCommandHistory : POINTER TO INTEGER32;
        pNext : POINTER TO D3D12_AUTO_BREADCRUMB_NODE;
    END;
    D3D12_AUTO_BREADCRUMB_NODE1 = RECORD
        pCommandListDebugNameA : POINTER TO BYTE;
        pCommandListDebugNameW : PWSTR;
        pCommandQueueDebugNameA : POINTER TO BYTE;
        pCommandQueueDebugNameW : PWSTR;
        pCommandList : ADDRESS;
        pCommandQueue : ADDRESS;
        BreadcrumbCount : DWORD;
        pLastBreadcrumbValue : POINTER TO DWORD;
        pCommandHistory : POINTER TO INTEGER32;
        pNext : POINTER TO D3D12_AUTO_BREADCRUMB_NODE1;
        BreadcrumbContextsCount : DWORD;
        pBreadcrumbContexts : POINTER TO D3D12_DRED_BREADCRUMB_CONTEXT;
    END;
    D3D12_BARRIER_GROUP = RECORD
        Type_ : INTEGER32;
        NumBarriers : DWORD;
        Anonymous : ADDRESS;
    END;
    D3D12_BARRIER_SUBRESOURCE_RANGE = RECORD
        IndexOrFirstMipLevel : DWORD;
        NumMipLevels : DWORD;
        FirstArraySlice : DWORD;
        NumArraySlices : DWORD;
        FirstPlane : DWORD;
        NumPlanes : DWORD;
    END;
    D3D12_BLEND_DESC = RECORD
        AlphaToCoverageEnable : BOOL;
        IndependentBlendEnable : BOOL;
        RenderTarget : ARRAY [0..319] OF BYTE;
    END;
    D3D12_BOX = RECORD
        left : DWORD;
        top : DWORD;
        front : DWORD;
        right : DWORD;
        bottom : DWORD;
        back : DWORD;
    END;
    D3D12_BROADCASTING_LAUNCH_OVERRIDES = RECORD
        pLocalRootArgumentsTableIndex : POINTER TO DWORD;
        pProgramEntry : POINTER TO BOOL;
        pNewName : POINTER TO D3D12_NODE_ID;
        pShareInputOf : POINTER TO D3D12_NODE_ID;
        pDispatchGrid : POINTER TO DWORD;
        pMaxDispatchGrid : POINTER TO DWORD;
        NumOutputOverrides : DWORD;
        pOutputOverrides : POINTER TO D3D12_NODE_OUTPUT_OVERRIDES;
    END;
    D3D12_BUFFER_BARRIER = RECORD
        SyncBefore : INTEGER32;
        SyncAfter : INTEGER32;
        AccessBefore : INTEGER32;
        AccessAfter : INTEGER32;
        pResource : ADDRESS;
        Offset : QWORD;
        Size : QWORD;
    END;
    D3D12_BUFFER_RTV = RECORD
        FirstElement : QWORD;
        NumElements : DWORD;
    END;
    D3D12_BUFFER_SRV = RECORD
        FirstElement : QWORD;
        NumElements : DWORD;
        StructureByteStride : DWORD;
        Flags : INTEGER32;
    END;
    D3D12_BUFFER_UAV = RECORD
        FirstElement : QWORD;
        NumElements : DWORD;
        StructureByteStride : DWORD;
        CounterOffsetInBytes : QWORD;
        Flags : INTEGER32;
    END;
    D3D12_BUILD_RAYTRACING_ACCELERATION_STRUCTURE_DESC = RECORD
        DestAccelerationStructureData : QWORD;
        Inputs : D3D12_BUILD_RAYTRACING_ACCELERATION_STRUCTURE_INPUTS;
        SourceAccelerationStructureData : QWORD;
        ScratchAccelerationStructureData : QWORD;
    END;
    D3D12_BUILD_RAYTRACING_ACCELERATION_STRUCTURE_INPUTS = RECORD
        Type_ : INTEGER32;
        Flags : INTEGER32;
        NumDescs : DWORD;
        DescsLayout : INTEGER32;
