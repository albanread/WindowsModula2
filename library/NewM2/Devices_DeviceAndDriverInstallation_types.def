TYPE
    BUSNUMBER_DES = RECORD
        BUSD_Count : DWORD;
        BUSD_Type : DWORD;
        BUSD_Flags : DWORD;
        BUSD_Alloc_Base : DWORD;
        BUSD_Alloc_End : DWORD;
    END;
    BUSNUMBER_RANGE = RECORD
        BUSR_Min : DWORD;
        BUSR_Max : DWORD;
        BUSR_nBusNumbers : DWORD;
        BUSR_Flags : DWORD;
    END;
    BUSNUMBER_RESOURCE = RECORD
        BusNumber_Header : BUSNUMBER_DES;
        BusNumber_Data : ARRAY [0..15] OF BYTE;
    END;
    CABINET_INFO_A = RECORD
        CabinetPath : PSTR;
        CabinetFile : PSTR;
        DiskName : PSTR;
        SetId : WORD;
        CabinetNumber : WORD;
    END;
    CABINET_INFO_W = RECORD
        CabinetPath : PWSTR;
        CabinetFile : PWSTR;
        DiskName : PWSTR;
        SetId : WORD;
        CabinetNumber : WORD;
    END;
    CM_NOTIFY_EVENT_DATA = RECORD
        FilterType : INTEGER32;
        Reserved : DWORD;
        u : ADDRESS;
    END;
    CM_NOTIFY_FILTER = RECORD
        cbSize : DWORD;
        Flags : DWORD;
        FilterType : INTEGER32;
        Reserved : DWORD;
        u : ADDRESS;
    END;
    COINSTALLER_CONTEXT_DATA = RECORD
        PostProcessing : BOOL;
        InstallResult : DWORD;
        PrivateData : ADDRESS;
    END;
    CONFLICT_DETAILS_A = RECORD
        CD_ulSize : DWORD;
        CD_ulMask : DWORD;
        CD_dnDevInst : DWORD;
        CD_rdResDes : ADRCARD;
        CD_ulFlags : DWORD;
        CD_szDescription : ARRAY [0..259] OF BYTE;
    END;
    CONFLICT_DETAILS_W = RECORD
        CD_ulSize : DWORD;
        CD_ulMask : DWORD;
        CD_dnDevInst : DWORD;
        CD_rdResDes : ADRCARD;
        CD_ulFlags : DWORD;
        CD_szDescription : ARRAY [0..261] OF CHAR;
    END;
    CONNECTION_DES = RECORD
        COND_Type : DWORD;
        COND_Flags : DWORD;
        COND_Class : BYTE;
        COND_ClassType : BYTE;
        COND_Reserved1 : BYTE;
        COND_Reserved2 : BYTE;
        COND_Id : INTEGER64;
    END;
    CONNECTION_RESOURCE = RECORD
        Connection_Header : CONNECTION_DES;
    END;
    CS_DES = RECORD
        CSD_SignatureLength : DWORD;
        CSD_LegacyDataOffset : DWORD;
        CSD_LegacyDataSize : DWORD;
        CSD_Flags : DWORD;
        CSD_ClassGuid : GUID;
        CSD_Signature : ARRAY [0..7] OF BYTE;
    END;
    CS_RESOURCE = RECORD
        CS_Header : CS_DES;
    END;
    DEVPRIVATE_DES = RECORD
        PD_Count : DWORD;
        PD_Type : DWORD;
        PD_Data1 : DWORD;
