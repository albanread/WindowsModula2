        coni1_netname : PWSTR;
    END;
    COPYFILE2_CREATE_OPLOCK_KEYS = RECORD
        ParentOplockKey : GUID;
        TargetOplockKey : GUID;
    END;
    COPYFILE2_EXTENDED_PARAMETERS = RECORD
        dwSize : DWORD;
        dwCopyFlags : DWORD;
        pfCancel : POINTER TO BOOL;
        pProgressRoutine : ADDRESS;
        pvCallbackContext : ADDRESS;
    END;
    COPYFILE2_EXTENDED_PARAMETERS_V2 = RECORD
        dwSize : DWORD;
        dwCopyFlags : DWORD;
        pfCancel : POINTER TO BOOL;
        pProgressRoutine : ADDRESS;
        pvCallbackContext : ADDRESS;
        dwCopyFlagsV2 : DWORD;
        ioDesiredSize : DWORD;
        ioDesiredRate : DWORD;
