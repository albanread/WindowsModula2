TYPE
    BY_HANDLE_FILE_INFORMATION = RECORD
        dwFileAttributes : DWORD;
        ftCreationTime : Foundation.FILETIME;
        ftLastAccessTime : Foundation.FILETIME;
        ftLastWriteTime : Foundation.FILETIME;
        dwVolumeSerialNumber : DWORD;
        nFileSizeHigh : DWORD;
        nFileSizeLow : DWORD;
        nNumberOfLinks : DWORD;
        nFileIndexHigh : DWORD;
        nFileIndexLow : DWORD;
    END;
    CLFS_LOG_NAME_INFORMATION = RECORD
        NameLengthInBytes : WORD;
        Name : ARRAY [0..0] OF CHAR;
    END;
    CLFS_MGMT_NOTIFICATION = RECORD
        Notification : INTEGER32;
        Lsn : CLS_LSN;
        LogIsPinned : WORD;
    END;
    CLFS_MGMT_POLICY = RECORD
        Version : DWORD;
        LengthInBytes : DWORD;
        PolicyFlags : DWORD;
        PolicyType : INTEGER32;
        PolicyParameters : ADDRESS;
    END;
    CLFS_NODE_ID = RECORD
        cType : DWORD;
        cbNode : DWORD;
    END;
    CLFS_PHYSICAL_LSN_INFORMATION = RECORD
        StreamIdentifier : BYTE;
        VirtualLsn : CLS_LSN;
        PhysicalLsn : CLS_LSN;
    END;
    CLFS_STREAM_ID_INFORMATION = RECORD
        StreamIdentifier : BYTE;
    END;
    CLS_ARCHIVE_DESCRIPTOR = RECORD
        coffLow : QWORD;
        coffHigh : QWORD;
        infoContainer : CLS_CONTAINER_INFORMATION;
    END;
    CLS_CONTAINER_INFORMATION = RECORD
        FileAttributes : DWORD;
        CreationTime : QWORD;
        LastAccessTime : QWORD;
        LastWriteTime : QWORD;
        ContainerSize : INTEGER64;
        FileNameActualLength : DWORD;
        FileNameLength : DWORD;
        FileName : ARRAY [0..255] OF CHAR;
        State : DWORD;
        PhysicalContainerId : DWORD;
        LogicalContainerId : DWORD;
    END;
    CLS_INFORMATION = RECORD
        TotalAvailable : INTEGER64;
        CurrentAvailable : INTEGER64;
        TotalReservation : INTEGER64;
        BaseFileSize : QWORD;
        ContainerSize : QWORD;
        TotalContainers : DWORD;
        FreeContainers : DWORD;
        TotalClients : DWORD;
        Attributes : DWORD;
        FlushThreshold : DWORD;
        SectorSize : DWORD;
        MinArchiveTailLsn : CLS_LSN;
        BaseLsn : CLS_LSN;
        LastFlushedLsn : CLS_LSN;
        LastLsn : CLS_LSN;
        RestartLsn : CLS_LSN;
        Identity : GUID;
    END;
    CLS_IO_STATISTICS = RECORD
        hdrIoStats : CLS_IO_STATISTICS_HEADER;
        cFlush : QWORD;
        cbFlush : QWORD;
        cMetaFlush : QWORD;
        cbMetaFlush : QWORD;
    END;
    CLS_IO_STATISTICS_HEADER = RECORD
        ubMajorVersion : BYTE;
        ubMinorVersion : BYTE;
        eStatsClass : INTEGER32;
        cbLength : WORD;
        coffData : DWORD;
    END;
    CLS_LSN = RECORD
        Internal : QWORD;
    END;
    CLS_SCAN_CONTEXT = RECORD
        cidNode : CLFS_NODE_ID;
        hLog : HANDLE;
        cIndex : DWORD;
        cContainers : DWORD;
        cContainersReturned : DWORD;
        eScanMode : BYTE;
        pinfoContainer : POINTER TO CLS_CONTAINER_INFORMATION;
    END;
    CLS_WRITE_ENTRY = RECORD
        Buffer : ADDRESS;
        ByteLength : DWORD;
    END;
    CONNECTION_INFO_0 = RECORD
        coni0_id : DWORD;
    END;
    CONNECTION_INFO_1 = RECORD
        coni1_id : DWORD;
        coni1_type : DWORD;
        coni1_num_opens : DWORD;
        coni1_num_users : DWORD;
        coni1_time : DWORD;
