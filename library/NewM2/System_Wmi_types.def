TYPE
    MI_Application = RECORD
        reserved1 : QWORD;
        reserved2 : ADRINT;
        ft : POINTER TO MI_ApplicationFT;
    END;
    MI_ApplicationFT = RECORD
        Close : ADRINT;
        NewSession : ADRINT;
        NewHostedProvider : ADRINT;
        NewInstance : ADRINT;
        NewDestinationOptions : ADRINT;
        NewOperationOptions : ADRINT;
        NewSubscriptionDeliveryOptions : ADRINT;
        NewSerializer : ADRINT;
        NewDeserializer : ADRINT;
        NewInstanceFromClass : ADRINT;
        NewClass : ADRINT;
    END;
    MI_Array = RECORD
        data : ADDRESS;
        size : DWORD;
    END;
    MI_ArrayField = RECORD
        value : MI_Array;
        exists : BYTE;
        flags : BYTE;
    END;
    MI_BooleanA = RECORD
        data : POINTER TO BYTE;
        size : DWORD;
    END;
    MI_BooleanAField = RECORD
        value : MI_BooleanA;
        exists : BYTE;
        flags : BYTE;
    END;
    MI_BooleanField = RECORD
        value : BYTE;
        exists : BYTE;
        flags : BYTE;
    END;
    MI_Char16A = RECORD
        data : POINTER TO WORD;
        size : DWORD;
    END;
    MI_Char16AField = RECORD
        value : MI_Char16A;
        exists : BYTE;
        flags : BYTE;
    END;
    MI_Char16Field = RECORD
        value : WORD;
        exists : BYTE;
        flags : BYTE;
    END;
    MI_Class = RECORD
        ft : POINTER TO MI_ClassFT;
        classDecl : POINTER TO MI_ClassDecl;
        namespaceName : POINTER TO WORD;
        serverName : POINTER TO WORD;
        reserved : ARRAY [0..3] OF ADRINT;
    END;
    MI_ClassDecl = RECORD
        flags : DWORD;
        code : DWORD;
        name : POINTER TO WORD;
