        fMouse : BOOL;
        hWndActive : HWND;
    END;
    CBT_CREATEWNDA = RECORD
        lpcs : POINTER TO CREATESTRUCTA;
        hwndInsertAfter : HWND;
    END;
    CBT_CREATEWNDW = RECORD
        lpcs : POINTER TO CREATESTRUCTW;
        hwndInsertAfter : HWND;
    END;
    CHANGEFILTERSTRUCT = RECORD
        cbSize : DWORD;
        ExtStatus : DWORD;
    END;
    CLIENTCREATESTRUCT = RECORD
        hWindowMenu : HANDLE;
        idFirstChild : DWORD;
    END;
    CREATESTRUCTA = RECORD
        lpCreateParams : ADDRESS;
        hInstance : HINSTANCE;
        hMenu : HMENU;
        hwndParent : HWND;
        cy : INTEGER32;
        cx : INTEGER32;
        y : INTEGER32;
        x : INTEGER32;
        style : INTEGER32;
        lpszName : PSTR;
        lpszClass : PSTR;
        dwExStyle : DWORD;
    END;
    CREATESTRUCTW = RECORD
        lpCreateParams : ADDRESS;
        hInstance : HINSTANCE;
        hMenu : HMENU;
        hwndParent : HWND;
        cy : INTEGER32;
        cx : INTEGER32;
        y : INTEGER32;
        x : INTEGER32;
        style : INTEGER32;
        lpszName : PWSTR;
        lpszClass : PWSTR;
        dwExStyle : DWORD;
    END;
    CURSORINFO = RECORD
        cbSize : DWORD;
        flags : DWORD;
        hCursor : HCURSOR;
        ptScreenPos : Foundation.POINT;
    END;
    CURSORSHAPE = RECORD
        xHotSpot : INTEGER32;
        yHotSpot : INTEGER32;
        cx : INTEGER32;
        cy : INTEGER32;
        cbWidth : INTEGER32;
        Planes : BYTE;
        BitsPixel : BYTE;
