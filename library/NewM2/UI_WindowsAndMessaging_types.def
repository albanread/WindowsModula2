TYPE
    ACCEL = RECORD
        fVirt : BYTE;
        key : WORD;
        cmd : WORD;
    END;
    ALTTABINFO = RECORD
        cbSize : DWORD;
        cItems : INTEGER32;
        cColumns : INTEGER32;
        cRows : INTEGER32;
        iColFocus : INTEGER32;
        iRowFocus : INTEGER32;
        cxItem : INTEGER32;
        cyItem : INTEGER32;
        ptStart : Foundation.POINT;
    END;
    ANIMATIONINFO = RECORD
        cbSize : DWORD;
        iMinAnimate : INTEGER32;
    END;
