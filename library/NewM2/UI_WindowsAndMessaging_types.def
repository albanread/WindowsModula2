        lResult : LRESULT;
        lParam : LPARAM;
        wParam : WPARAM;
        message : DWORD;
        hwnd : HWND;
    END;
    CWPSTRUCT = RECORD
        lParam : LPARAM;
        wParam : WPARAM;
        message : DWORD;
        hwnd : HWND;
    END;
