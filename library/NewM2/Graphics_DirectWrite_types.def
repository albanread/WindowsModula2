        glyphRun : DWRITE_GLYPH_RUN;
        glyphRunDescription : POINTER TO DWRITE_GLYPH_RUN_DESCRIPTION;
        baselineOriginX : REAL;
        baselineOriginY : REAL;
        runColor : DWRITE_COLOR_F;
        paletteIndex : WORD;
    END;
    DWRITE_COLOR_GLYPH_RUN1 = RECORD
        Base : DWRITE_COLOR_GLYPH_RUN;
        glyphImageFormat : INTEGER32;
        measuringMode : INTEGER32;
    END;
