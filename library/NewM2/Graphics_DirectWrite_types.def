        axisTag : DWORD;
        minValue : REAL;
        maxValue : REAL;
    END;
    DWRITE_FONT_AXIS_VALUE = RECORD
        axisTag : DWORD;
        value : REAL;
    END;
    DWRITE_FONT_FEATURE = RECORD
        nameTag : DWORD;
        parameter : DWORD;
    END;
    DWRITE_FONT_METRICS = RECORD
        designUnitsPerEm : WORD;
        ascent : WORD;
        descent : WORD;
        lineGap : INTEGER16;
        capHeight : WORD;
        xHeight : WORD;
        underlinePosition : INTEGER16;
        underlineThickness : WORD;
        strikethroughPosition : INTEGER16;
        strikethroughThickness : WORD;
    END;
    DWRITE_FONT_METRICS1 = RECORD
        Base : DWRITE_FONT_METRICS;
        glyphBoxLeft : INTEGER16;
        glyphBoxTop : INTEGER16;
        glyphBoxRight : INTEGER16;
        glyphBoxBottom : INTEGER16;
        subscriptPositionX : INTEGER16;
        subscriptPositionY : INTEGER16;
        subscriptSizeX : INTEGER16;
        subscriptSizeY : INTEGER16;
        superscriptPositionX : INTEGER16;
        superscriptPositionY : INTEGER16;
        superscriptSizeX : INTEGER16;
        superscriptSizeY : INTEGER16;
        hasTypographicMetrics : BOOL;
    END;
    DWRITE_FONT_PROPERTY = RECORD
        propertyId : INTEGER32;
        propertyValue : PWSTR;
        localeName : PWSTR;
    END;
    DWRITE_GLYPH_IMAGE_DATA = RECORD
        imageData : ADDRESS;
        imageDataSize : DWORD;
        uniqueDataId : DWORD;
        pixelsPerEm : DWORD;
        pixelSize : Graphics_Direct2D_Common.D2D_SIZE_U;
        horizontalLeftOrigin : Foundation.POINT;
        horizontalRightOrigin : Foundation.POINT;
        verticalTopOrigin : Foundation.POINT;
        verticalBottomOrigin : Foundation.POINT;
    END;
    DWRITE_GLYPH_METRICS = RECORD
        leftSideBearing : INTEGER32;
        advanceWidth : DWORD;
        rightSideBearing : INTEGER32;
        topSideBearing : INTEGER32;
        advanceHeight : DWORD;
        bottomSideBearing : INTEGER32;
        verticalOriginY : INTEGER32;
    END;
    DWRITE_GLYPH_OFFSET = RECORD
        advanceOffset : REAL;
        ascenderOffset : REAL;
    END;
    DWRITE_GLYPH_RUN = RECORD
        fontFace : ADDRESS;
        fontEmSize : REAL;
        glyphCount : DWORD;
        glyphIndices : POINTER TO WORD;
        glyphAdvances : POINTER TO REAL;
        glyphOffsets : POINTER TO DWRITE_GLYPH_OFFSET;
        isSideways : BOOL;
        bidiLevel : DWORD;
    END;
    DWRITE_GLYPH_RUN_DESCRIPTION = RECORD
        localeName : PWSTR;
        string : PWSTR;
        stringLength : DWORD;
        clusterMap : POINTER TO WORD;
        textPosition : DWORD;
    END;
    DWRITE_HIT_TEST_METRICS = RECORD
        textPosition : DWORD;
        length : DWORD;
        left : REAL;
        top : REAL;
        width : REAL;
        height : REAL;
        bidiLevel : DWORD;
        isText : BOOL;
        isTrimmed : BOOL;
    END;
    DWRITE_INLINE_OBJECT_METRICS = RECORD
