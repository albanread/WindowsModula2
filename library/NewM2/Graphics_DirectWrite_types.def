TYPE
    DWRITE_BITMAP_DATA_BGRA32 = RECORD
        width : DWORD;
        height : DWORD;
        pixels : POINTER TO DWORD;
    END;
    DWRITE_CARET_METRICS = RECORD
        slopeRise : INTEGER16;
        slopeRun : INTEGER16;
        offset : INTEGER16;
    END;
    DWRITE_CLUSTER_METRICS = RECORD
        width : REAL;
        length : WORD;
        _bitfield : WORD;
    END;
