TYPE
    WSMAN_API_HANDLE = RECORD
        Value : ADRINT;
    END;
    WSMAN_AUTHENTICATION_CREDENTIALS = RECORD
        authenticationMechanism : DWORD;
        Anonymous : ADDRESS;
    END;
    WSMAN_AUTHZ_QUOTA = RECORD
        maxAllowedConcurrentShells : DWORD;
        maxAllowedConcurrentOperations : DWORD;
        timeslotSize : DWORD;
        maxAllowedOperationsPerTimeslot : DWORD;
    END;
    WSMAN_CERTIFICATE_DETAILS = RECORD
        subject : PWSTR;
        issuerName : PWSTR;
        issuerThumbprint : PWSTR;
        subjectName : PWSTR;
    END;
    WSMAN_COMMAND_ARG_SET = RECORD
        argsCount : DWORD;
        args : POINTER TO PWSTR;
    END;
    WSMAN_COMMAND_HANDLE = RECORD
        Value : ADRINT;
    END;
    WSMAN_CONNECT_DATA = RECORD
        data : WSMAN_DATA;
    END;
    WSMAN_CREATE_SHELL_DATA = RECORD
        data : WSMAN_DATA;
    END;
    WSMAN_DATA = RECORD
        type_ : INTEGER32;
        Anonymous : ADDRESS;
    END;
    WSMAN_DATA_BINARY = RECORD
        dataLength : DWORD;
        data : POINTER TO BYTE;
    END;
    WSMAN_DATA_TEXT = RECORD
        bufferLength : DWORD;
        buffer : PWSTR;
    END;
    WSMAN_ENVIRONMENT_VARIABLE = RECORD
        name : PWSTR;
        value : PWSTR;
    END;
    WSMAN_ENVIRONMENT_VARIABLE_SET = RECORD
        varsCount : DWORD;
        vars : POINTER TO WSMAN_ENVIRONMENT_VARIABLE;
    END;
    WSMAN_ERROR = RECORD
        code : DWORD;
        errorDetail : PWSTR;
        language : PWSTR;
        machineName : PWSTR;
        pluginName : PWSTR;
    END;
    WSMAN_FILTER = RECORD
        filter : PWSTR;
        dialect : PWSTR;
    END;
    WSMAN_FRAGMENT = RECORD
        path : PWSTR;
        dialect : PWSTR;
    END;
    WSMAN_KEY = RECORD
        key : PWSTR;
        value : PWSTR;
    END;
    WSMAN_OPERATION_HANDLE = RECORD
        Value : ADRINT;
    END;
